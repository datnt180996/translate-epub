APP_NAME=ebook-translator
DATABASE_URL=sqlite:///./ebook_translator.db
APP_HOST=127.0.0.1
APP_PORT=8000

# Minimax (primary translation provider)
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_MODEL=MiniMax-M2.7-highspeed
MINIMAX_BASE_URL=https://api.minimax.io/v1

# DeepSeek (secondary translation provider)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Fetching
REQUEST_TIMEOUT=30
USE_CURL_CFFI_FALLBACK=true
USE_PLAYWRIGHT_FALLBACK=false

# Translation tuning
TRANSLATION_MAX_CHUNK_CHARS=1000
TRANSLATION_CONCURRENCY=2
TRANSLATION_TIMEOUT=600
TRANSLATION_MAX_RETRIES=2
TRANSLATION_MAX_OUTPUT_TOKENS=8192
AUTO_EXTRACT_GLOSSARY=true
AUTO_SUMMARIZE_CHAPTER=true

# Auto fetch raw chapter content after URL import
AUTO_FETCH_AFTER_IMPORT=true
FETCH_BATCH_SIZE=50
FETCH_CONCURRENCY=3
FETCH_REQUEST_DELAY=0.3
FETCH_MAX_RETRIES=2
